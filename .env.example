# ===== MongoDB =====
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sellanything?retryWrites=true&w=majority

# ===== Server =====
PORT=5000
NODE_ENV=production
BASE_URL=https://yourdomain.com

# ===== Cloudinary (image storage) =====
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== Firebase Admin SDK (server-side token verification) =====
# Generate this from Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
# Paste the ENTIRE JSON contents as a single line string here
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ===== Commission =====
COMMISSION_PERCENT=5

# ===== Google Site Verification (paste the content value Google gives you) =====
GOOGLE_SITE_VERIFICATION=paste_your_verification_code_here
